    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "runtimeVersion": "19",
            "request": "launch",
            "name": "Launch NIMS",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "cwd": "${workspaceRoot}",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run", "watch:standalone"
            ],
            "port": 8080,
            //"program": "${workspaceFolder}/packages/nims-app/app/pages/index.js",
        }
    ]
}